// Example 3 — conditional update based on win/loss
// app/api/game/result/route.ts

export async function POST(req: Request) {
  const body = await req.json();

  const { game, result } = body;

  const userId = "USER_ID_FROM_SESSION";   // TODO Information from session / auth

  const isWin = result === "win";

  const score = await prisma.score.upsert({
    where: {
      accountId_game: {
        accountId: userId,
        game: game
      }
    },
    update: {
      gamesPlayed: { increment: 1 },
      gamesWon: isWin ? { increment: 1 } : undefined,
      gamesLost: !isWin ? { increment: 1 } : undefined
    },
    create: {
      accountId: userId,
      game: game,
      gamesPlayed: 1,
      gamesWon: isWin ? 1 : 0,
      gamesLost: isWin ? 0 : 1
    }
  });

  return Response.json(score);
}
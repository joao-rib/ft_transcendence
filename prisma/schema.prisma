// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  //output = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Account: Contas e autenticações

model Account {
  id            String   @id @default(uuid()) // Unique key. Default value generator. Universally unique identifier.
  username      String   @unique // Must be unique
  email         String   @unique // Must be unique
  password      String
  passwordHash  String?           // Nullable
  emailVerified DateTime?         // Nullable
  createdAt     DateTime @default(now()) // Default value generator. Records current timestamp
  updatedAt     DateTime @updatedAt      // Records timestamp for most recent change

  avatarUrl     String?   // Nullable
  onlineStatus  OnlineStatus @default(OFFLINE)
  score         Score?

  // oauthAccounts OAuthAccount[] // Number of OAuth accounts
  friendshipsAsUserA Friendship[] @relation("FriendshipUserA")
  friendshipsAsUserB Friendship[] @relation("FriendshipUserB")
  refreshTokens RefreshToken[]
}

// Score: Player record for each game

/*enum Game {
  chess
  checkers
  sueca
}*/

enum OnlineStatus {
  ONLINE
  OFFLINE
}

model Score {
  id            String   @id @default(uuid()) // Unique key. Default value generator. Universally unique identifier.
  rating        Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)

  account       Account  @relation(fields: [accountId], references: [id]) // Defines a foreign key relationship
  accountId     String   @unique // One score row per account (chess only)
}

model Friendship {
  id        String   @id @default(uuid())
  userA     Account  @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userAId   String
  userB     Account  @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userBId])
}


generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Account: User account & player profile

model Account {
  id            String   @id @default(uuid()) // Unique key. Default value generator. Universally unique identifier.
  username      String   @unique              // Must be unique
  email         String   @unique              // Must be unique
  passwordHash  String?                  // Nullable
  emailVerified DateTime?                // Nullable
  createdAt     DateTime @default(now()) // Default value generator. Records current timestamp
  updatedAt     DateTime @updatedAt      // Records timestamp for most recent change

  avatarUrl     String?   // Nullable
  scores        Score[]

  oauthAccounts OAuthAccount[] // Number of OAuth accounts
  refreshTokens RefreshToken[]
}

// Score: Player record for each game

enum Game {
  chess
  checkers
  sueca
}

enum Rank {
  Beginner
  Intermediate
  Expert
}

model Score {
  id            String   @id @default(uuid()) // Unique key. Default value generator. Universally unique identifier.
  game          Game
  title         Rank
  gamesPlayed   Int      @default(0)
  gamesWon      Int      @default(0)
  gamesLost     Int      @default(0)

  account     Account @relation(fields: [accountId], references: [id]) // Defines a foreign key relationship
  accountId   String

  @@unique([accountId, game]) // Combination of fields must be unique
}

enum OAuthProvider {
  google
  github
  apple
}

model OAuthAccount {
  id                String  @id @default(uuid()) // Unique key. Default value generator. Universally unique identifier.
  provider          OAuthProvider
  providerAccountId String

  account           Account @relation(fields: [accountId], references: [id], onDelete: Cascade) // Defines a foreign key relationship
  accountId         String  @unique // Must be unique

  @@unique([provider, providerAccountId]) // Combination of fields must be unique
}

model RefreshToken {
  id         String   @id @default(uuid())  // Unique key. Default value generator. Universally unique identifier.
  tokenHash  String   @unique               // Must be unique
  expiresAt  DateTime
  revokedAt  DateTime?                      // Nullable
  createdAt  DateTime @default(now())       // Default value generator. Records current timestamp

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade) // Defines a foreign key relationship
  accountId String    // Not unique. Allows user to mantain sessions from different devices
}

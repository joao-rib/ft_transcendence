model RefreshToken {
  id         String   @id @default(uuid())  // Unique key. Default value generator. Universally unique identifier.
  tokenHash  String   @unique               // Must be unique
  expiresAt  DateTime
  revokedAt  DateTime?                      // Nullable
  createdAt  DateTime @default(now())       // Default value generator. Records current timestamp

  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade) // Defines a foreign key relationship
  accountId  String   @unique               // Must be unique
}

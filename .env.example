# ── Base de dados ──────────────────────────────────────────────────────────────
# Utilizador da base de dados PostgreSQL
DB_USER=transcendence_user
# Palavra-passe da base de dados (MUDA isto antes de partilhar com a equipa)
DB_PASSWORD=changeme
# Nome da base de dados
DB_NAME=transcendence_db
# URL usada por comandos locais (pnpm prisma, scripts no host)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
# URL usada por serviços dentro do Docker (hostname interno "db")
DATABASE_URL_DOCKER=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# ── Frontend ────────────────────────────────────────────────────────────────────
# Porta interna do servidor Next.js (não é exposta externamente; o Nginx faz isso)
FRONTEND_PORT=3000

# ── API Backend ─────────────────────────────────────────────────────────────────
# URL que o frontend usa para chamar a API REST (visto do browser através do Nginx)
NEXT_PUBLIC_API_URL=https://localhost/api
# URL do WebSocket (wss = WebSocket seguro, passando pelo Nginx)
NEXT_PUBLIC_WS_URL=wss://localhost/ws

# ── Certificados SSL (Nginx) ────────────────────────────────────────────────────
# Pasta dentro do container Nginx onde os certificados são guardados
CRED_PATH=/etc/nginx/ssl

# ── Auth / JWT ──────────────────────────────────────────────────────────────────
# Segredo usado para assinar tokens JWT (muda para algo aleatório e longo)
JWT_SECRET=supersecretjwtkey_changeme


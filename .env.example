# ---- Database -----------------------------------------------------------------
# PostgreSQL database user
DB_USER=changemeuser
# PostgreSQL database password (change before sharing with the team)
DB_PASSWORD=changemepass1
# PostgreSQL database name
DB_NAME=changemedb
# URL used by local host commands (pnpm prisma, host scripts)
DATABASE_URL=postgresql://changemeuser:changemepass1@localhost:5432/changemedb
# URL used by services running inside Docker (internal host "db")
DATABASE_URL_DOCKER=postgresql://changemeuser:changemepass1@db:5432/changemedb

# ---- Authentication -----------------------------------------------------------
# Secret used to sign NextAuth JWT/session cookies (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=replace_with_a_strong_secret
# Canonical app URL used by NextAuth callbacks
NEXTAUTH_URL=https://localhost

# ---- Frontend -----------------------------------------------------------------
# Internal Next.js server port (not exposed publicly; Nginx handles external access)
FRONTEND_PORT=3000

# ---- API Backend ---------------------------------------------------------------
# Base URL used by the frontend to call the REST API via Nginx
NEXT_PUBLIC_API_URL=https://localhost/api
# WebSocket URL used by the frontend (secure WSS through Nginx)
NEXT_PUBLIC_WS_URL=wss://localhost/ws

# ---- SSL Certificates (Nginx) -------------------------------------------------
# Directory inside the Nginx container where certificates are stored
CRED_PATH=/etc/nginx/ssl
# Certificate filename generated/used by Nginx
CRED_CERT=transcendence.crt
# Private key filename generated/used by Nginx
CRED_KEY=transcendence.key
# Certificate subject fields used by generate-cert.sh
COUNTRY=PT
STATE=Porto
LOCALITY=Porto
ORGANIZATION=42Porto
ORG_UNIT=Student
COMMON_NAME=localhost
#To work at 42 school (Cannot be <1024). Example
#NGINX_HTTP_PORT=8080
#NGINX_HTTPS_PORT=8443
#Default
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- Auth / JWT ----------------------------------------------------------------
# Secret used to sign JWTs (replace with a long random value)
JWT_SECRET=supersecretjwtkey_changeme
